# Questrade Price Fetcher — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Long-lived refresh token from your Questrade API app
QUESTRADE_REFRESH_TOKEN=your_refresh_token_here

# Dynamic API server URL returned by the OAuth token endpoint.
# Leave blank on first run — updated automatically after authentication.
QUESTRADE_API_SERVER=
